[sub_resource type="GDScript" id="GDScript_pagemgr"]
script/source = "extends Control

# Page manager — shows/hides Page1-Page5 based on MPF player variable
# status_mode_page (1-5). MPF fires 'player_status_mode_page' when it changes.
# GMC 0.1.6 routes player variable events through its event bus.
# If pages don't switch: verify GMC event connection API in your version.

var _current_page: int = 1

func _ready() -> void:
	_show_page(1)
	# Connect to GMC event bus — adjust singleton name if needed
	var gmc = _find_gmc_singleton()
	if gmc and gmc.has_signal(\"mpf_event\"):
		gmc.connect(\"mpf_event\", _on_mpf_event)

func _find_gmc_singleton() -> Node:
	for name in [\"GameInterface\", \"BCP\", \"GMC\"]:
		if Engine.has_singleton(name):
			return Engine.get_singleton(name)
	return null

func _on_mpf_event(event_name: String, kwargs: Dictionary) -> void:
	if event_name == \"player_status_mode_page\":
		var page = int(kwargs.get(\"value\", 1))
		if page != _current_page:
			_current_page = page
			_show_page(page)

func _show_page(page_num: int) -> void:
	for i in range(1, 6):
		var page_node = get_node_or_null(\"Page%d\" % i)
		if page_node:
			page_node.visible = (i == page_num)
"

